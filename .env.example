# GraphXR MCP Hub — Environment Variables
# Copy this file to .env and fill in your values.

# ── GraphXR MCP Server ─────────────────────────────────────────────────────
# Port the MCP server listens on.
# GraphXR Agent (web frontend) auto-probes this port for discovery.
GRAPHXR_MCP_PORT=8899

# GraphXR web app WebSocket address (opened by GraphXR at runtime).
GRAPHXR_WS_URL=ws://localhost:8080

# Transport mode: "http" (SSE, for browser/frontend clients) or "stdio" (for CLI).
MCP_TRANSPORT=http

# ── genai-toolbox (optional) ───────────────────────────────────────────────
GENAI_TOOLBOX_URL=http://localhost:5000/sse

# ── Neo4j (optional, used in tools.yaml) ──────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# ── Google Cloud / Spanner (optional) ─────────────────────────────────────
GCP_PROJECT=
SPANNER_INSTANCE=
SPANNER_DATABASE=

# ── Google Cloud ADC Authentication (optional) ───────────────────────
# Option 1: Service account key file path (for Docker)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# Option 2: gcloud CLI config directory (for local dev, uses `gcloud auth application-default login`)
# CLOUDSDK_CONFIG=~/.config/gcloud

# ── BigQuery (optional) ──────────────────────────────────────────────
BIGQUERY_PROJECT=
BIGQUERY_LOCATION=us
BIGQUERY_ALLOWED_DATASETS=

# ── PostgreSQL (optional) ──────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

# ── Local data directory (used by filesystem MCP server) ──────────────────
DATA_DIR=./data

# ── Kafka (optional, enable kafka in hub_config.yaml) ────────────────────
KAFKA_WS_URL=ws://localhost:9092/ws

# ── Ollama (optional, enable ollama in hub_config.yaml) ──────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── GitHub (optional, enable github server in hub_config.yaml) ────────────
GITHUB_TOKEN=
