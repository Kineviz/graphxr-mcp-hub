{
  "name": "graphxr-mcp-hub",
  "version": "1.0.0",
  "description": "GraphXR MCP Hub — Multi-source data × MCP protocol × unified graph semantic layer × GraphXR integration",
  "main": "dist/graphxr_mcp_server/index.js",
  "scripts": {
    "build": "tsc",
    "start:graphxr-mcp": "node dist/graphxr_mcp_server/index.js",
    "dev:graphxr-mcp": "ts-node graphxr_mcp_server/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint 'graphxr_mcp_server/**/*.ts' 'semantic_layer/**/*.ts' 'mcp_client/**/*.ts' 'tests/**/*.ts'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "ws": "^8.16.0",
    "yaml": "^2.4.1",
    "zod": "^3.22.4",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vitest": "^1.2.2"
  },
  "keywords": ["graphxr", "mcp", "graph", "visualization", "agent"],
  "license": "MIT"
}
