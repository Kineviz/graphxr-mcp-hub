{
  "name": "@kineviz/graphxr_mcp_server",
  "version": "0.1.0",
  "description": "GraphXR MCP Hub — Multi-source data × MCP protocol × unified graph semantic layer × GraphXR integration",
  "main": "dist/graphxr_mcp_server/index.js",
  "bin": {
    "graphxr-mcp-server": "dist/graphxr_mcp_server/index.js"
  },
  "files": [
    "dist/graphxr_mcp_server/",
    "dist/semantic_layer/",
    "config/hub_config.yaml",
    "config/tools.yaml.example",
    "config/ollama_config.ts",
    "admin_ui/dist/",
    "examples/"
  ],
  "scripts": {
    "ensure-config": "tsx scripts/ensure-config.ts",
    "build": "tsc && node -e \"const fs=require('fs'),f='dist/graphxr_mcp_server/index.js',c=fs.readFileSync(f,'utf8');if(!c.startsWith('#!'))fs.writeFileSync(f,'#!/usr/bin/env node\\n'+c);\" && yarn build:admin",
    "build:server": "tsc && node -e \"const fs=require('fs'),f='dist/graphxr_mcp_server/index.js',c=fs.readFileSync(f,'utf8');if(!c.startsWith('#!'))fs.writeFileSync(f,'#!/usr/bin/env node\\n'+c);\"",
    "prepublishOnly": "npm run build",
    "build:admin": "cd admin_ui && yarn install && yarn build",
    "dev:admin": "cd admin_ui && yarn dev",
    "prestart": "tsx scripts/ensure-config.ts",
    "start": "node dist/graphxr_mcp_server/index.js",
    "predev": "tsx scripts/ensure-config.ts",
    "dev": "npx kill-port 8899 && tsx watch graphxr_mcp_server/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint 'graphxr_mcp_server/**/*.ts' 'semantic_layer/**/*.ts' 'mcp_client/**/*.ts' 'tests/**/*.ts'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "duckdb": "^1.4.4",
    "express": "^4.18.2",
    "ws": "^8.16.0",
    "yaml": "^2.4.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.2"
  },
  "keywords": [
    "graphxr",
    "mcp",
    "graph",
    "visualization",
    "agent"
  ],
  "license": "MIT"
}
